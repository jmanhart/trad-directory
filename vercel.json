{
  "installCommand": "npm install --include=dev",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Document-Policy",
          "value": "js-profiling"
        }
      ]
    }
  ],
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "env": {
    "NPM_CONFIG_PRODUCTION": "false"
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true
    }
  },
  "crons": [
    {
      "path": "/api/checkInstagramLinks",
      "schedule": "*/15 2-6 * * *"
    }
  ]
}